# Copy this file to .env and fill in your key.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# Optional overrides (defaults shown)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_TEMPERATURE=0
# OSINT_HEADLESS=false
# OSINT_MAX_STEPS=50
# OSINT_HTTP_TIMEOUT=10
# OSINT_HTTP_RETRIES=3
# OSINT_LOG_LEVEL=INFO

# Responsible-use controls (defaults shown)
# OSINT_RESPECT_ROBOTS=true        # honor robots.txt when navigating
# OSINT_REQUEST_DELAY=1.0          # min seconds between page navigations
# OSINT_USER_AGENT=osint-agent/1.0 (+https://github.com/giovanniromero-dev/osint-agent)
# OSINT_STEALTH=false              # anti-bot fingerprint spoofing. Only enable for
#                                  # sources you are AUTHORIZED to test; may breach ToS.

# Advanced tuning (defaults shown) — rarely needed
# OSINT_RECURSION_LIMIT=200        # max steps in the LangGraph agent loop
# OSINT_NAV_TIMEOUT_MS=30000       # page navigation timeout (ms)
# OSINT_SEARCH_TIMEOUT_MS=20000    # DuckDuckGo search timeout (ms)
# OSINT_HTTP_BACKOFF=0.6           # backoff factor between HTTP retries
